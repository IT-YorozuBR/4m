{
  "version": 2,
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "templates/**",
          "css/**",
          "src/scripts/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/server.js" }
  ]
}
